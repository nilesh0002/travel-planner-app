// Prisma schema for Travel Planner
// Unit V: PostgreSQL modeling with Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


model Trip {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  user_id    String
  title      String
  start_date DateTime
  end_date   DateTime
  created_at DateTime         @default(now())
  items      ItineraryItem[]

  @@map("trips")
}

model ItineraryItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  trip_id     String   @db.ObjectId
  day         Int
  type        String?
  title       String
  location    String?
  time        String?
  description String?
  created_at  DateTime @default(now())
  trip        Trip     @relation(fields: [trip_id], references: [id], onDelete: Cascade)

  @@map("itinerary_items")
}

